# Local MySQL (the application's metadata DB — runs in docker-compose)
LOCAL_DB_HOST=mysql
LOCAL_DB_PORT=3306
LOCAL_DB_NAME=meteo_local
LOCAL_DB_USER=meteo
LOCAL_DB_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Remote sensor MySQL (read-only, lives outside docker-compose)
SENSOR_DB_HOST=
SENSOR_DB_PORT=
SENSOR_DB_NAME=
SENSOR_DB_USER=
SENSOR_DB_PASSWORD=

# Security
JWT_SECRET=
JWT_ACCESS_TTL=
JWT_REFRESH_TTL=

# Server
SERVER_PORT=

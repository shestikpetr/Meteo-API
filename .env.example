# Локальный MySQL (метаданные приложения: пользователи, станции, параметры)
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=3306
LOCAL_DB_NAME=meteo_local
LOCAL_DB_USER=meteo
LOCAL_DB_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Удалённая sensor-БД (показания датчиков; read-only, живёт вне compose).
SENSOR_DB_HOST=
SENSOR_DB_PORT=3306
SENSOR_DB_NAME=
SENSOR_DB_USER=
SENSOR_DB_PASSWORD=
# Для локальной тестовой БД без SSL false.
SENSOR_DB_USE_SSL=true

# JWT
JWT_SECRET=
JWT_ACCESS_TTL=86400
JWT_REFRESH_TTL=2592000

# Порт приложения
SERVER_PORT=8085
